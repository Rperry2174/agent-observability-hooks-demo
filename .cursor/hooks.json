{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "sessionEnd": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "preToolUse": [
      {
        "command": "node .cursor/hooks/enforce-typescript-pretool.mjs",
        "timeout": 10
      }
    ],
    "afterFileEdit": [
      {
        "command": "node .cursor/hooks/enforce-typescript.mjs",
        "timeout": 10
      },
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node .cursor/hooks/enforce-shell-policy.mjs",
        "timeout": 10
      },
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "afterShellExecution": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "afterMCPExecution": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ],
    "stop": [
      {
        "command": "node .cursor/hooks/audit-log.mjs"
      }
    ]
  }
}
